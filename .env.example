# Copy this file to .env and fill in your Prisma Postgres connection string.
# Find it in the Prisma Console: https://console.prisma.io → your project → Connect
DATABASE_URL="postgresql://user:password@host:5432/nbadle?sslmode=require"
# Secret key for HMAC hashing of NBA player IDs (used in URL params)
HASH_KEY="change-me-to-a-random-secret"
